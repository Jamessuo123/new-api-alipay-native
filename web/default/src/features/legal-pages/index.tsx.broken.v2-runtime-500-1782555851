function renderBody(block: Section['body'][number], index: number) {
  if (block.type === 'h3') {
    return <h3 key={index} style={styles.h3}>{block.text}</h3>
  }
  if (block.type === 'ul') {
    return (
      <ul key={index} style={styles.ul}>
        {block.items.map((item, i) => (
          <li key={i} style={styles.li}>{item}</li>
        ))}
      </ul>
    )
  }
  if (block.type === 'notice') {
    return <div key={index} style={styles.notice}>{block.text}</div>
  }
  return <p key={index} style={styles.p}>{block.text}</p>
}

